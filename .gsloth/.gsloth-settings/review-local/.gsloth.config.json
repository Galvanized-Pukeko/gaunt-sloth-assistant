{
  "llm": {
    "type": "openrouter",
    "model": "anthropic/claude-sonnet-4.6"
  },
  "filesystem": "read",
  "includeCurrentDateAfterGuidelines": true,
  "writeOutputToFile": true,
  "consoleLevel": "info",
  "organization": {
    "name": "Galvanized Pukeko",
    "locale": "en-NZ",
    "timezone": "Pacific/Auckland"
  },
  "commands": {
    "review": {
      "allowedTools": [],
      "rating": {
        "enabled": true,
        "passThreshold": 6,
        "errorOnReviewFail": true
      }
    },
    "pr": {
      "allowedTools": [],
      "auto": {
        "allowedTools": ["gh_pr", "gh_diff", "gh_issue"]
      },
      "rating": {
        "enabled": true,
        "passThreshold": 6,
        "errorOnReviewFail": true
      }
    }
  }
}
