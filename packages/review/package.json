{
  "name": "@gaunt-sloth/review",
  "version": "1.4.0",
  "description": "Review functionality for Gaunt Sloth",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gaunt-sloth-review": "cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*.js": "./dist/*.js"
  },
  "imports": {
    "#src/*.js": "./dist/*.js"
  },
  "dependencies": {
    "@gaunt-sloth/core": "*"
  },
  "peerDependencies": {
    "@gaunt-sloth/tools": "*",
    "@langchain/mcp-adapters": "^1.1.3",
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "peerDependenciesMeta": {
    "@gaunt-sloth/tools": {
      "optional": true
    },
    "@langchain/mcp-adapters": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "files": [
    "./dist/*",
    "cli.js"
  ],
  "scripts": {
    "build": "tsc"
  }
}