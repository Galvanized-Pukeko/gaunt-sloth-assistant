{
  "name": "@gaunt-sloth/api",
  "version": "0.0.1",
  "description": "API server for Gaunt Sloth",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gaunt-sloth-api": "cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*.js": "./dist/*.js"
  },
  "imports": {
    "#src/*.js": "./dist/*.js"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@ag-ui/core": "^0.0.47",
    "@ag-ui/encoder": "^0.0.47",
    "@gaunt-sloth/core": "^0.0.1",
    "@gaunt-sloth/tools": "^0.0.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1"
  },
  "files": [
    "./dist/*",
    "cli.js"
  ],
  "scripts": {
    "build": "tsc"
  }
}
