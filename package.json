{
  "name": "gaunt-sloth-assistant",
  "version": "1.4.0",
  "description": "",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "type": "module",
  "main": "dist/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Galvanized-Pukeko/gaunt-sloth-assistant.git"
  },
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "llm",
    "cli"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "tsc -b -clean",
    "build": "npm run build -w @gaunt-sloth/core && npm run build -w @gaunt-sloth/tools && npm run build -w @gaunt-sloth/api && npm run build -w @gaunt-sloth/review && tsc",
    "unit": "vitest run",
    "test": "npm run build && npx tsc -p spec/tsconfig.json --noEmit && vitest run",
    "it": "npm run build && node it.js",
    "it-verbose": "npm run build && GSLOTH_IT_VERBOSE=1 node it.js",
    "lint": "eslint . --ext .js,.ts",
    "lint-n-fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write 'src/**/*.{js,ts}'",
    "prepare": "echo 'skipping prepare'",
    "typedoc": "typedoc",
    "chat": "node cli.js"
  },
  "bin": {
    "gaunt-sloth-assistant": "cli.js",
    "gaunt-sloth": "cli.js",
    "gsloth": "cli.js",
    "gth": "cli.js"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@ag-ui/core": "^0.0.47",
    "@ag-ui/encoder": "^0.0.47",
    "@gaunt-sloth/api": "^1.4.0",
    "@gaunt-sloth/core": "^1.4.0",
    "@gaunt-sloth/review": "^1.4.0",
    "@gaunt-sloth/tools": "^1.4.0",
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.35",
    "@langchain/deepseek": "^1.0.18",
    "@langchain/google": "^0.1.8",
    "@langchain/groq": "^1.1.5",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.0",
    "@langchain/xai": "^1.3.10",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "diff": "^8.0.3",
    "express": "^5.2.1",
    "langchain": "^1.2.36",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "rimraf": "^6.1.0",
    "minimatch": "^10.2.4"
  },
  "imports": {
    "#src/*.js": "./dist/*.js"
  },
  "exports": {
    "./*": "./dist/*.js"
  },
  "types": "./dist/*",
  "files": [
    "./dist/*",
    "cli.js",
    ".gsloth.*.md"
  ]
}
