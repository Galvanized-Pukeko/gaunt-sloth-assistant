{
  "name": "gaunt-sloth-workspace",
  "version": "1.4.0",
  "private": true,
  "description": "Gaunt Sloth Assistant workspace",
  "license": "MIT",
  "author": "Andrew Kondratev",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Galvanized-Pukeko/gaunt-sloth-assistant.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build -w @gaunt-sloth/core && npm run build -w @gaunt-sloth/tools && npm run build -w @gaunt-sloth/api && npm run build -w @gaunt-sloth/review && npm run build -w gaunt-sloth-assistant",
    "unit": "vitest run",
    "test": "npm run build && vitest run",
    "it": "npm run build && node it.js",
    "it-verbose": "npm run build && GSLOTH_IT_VERBOSE=1 node it.js",
    "lint": "eslint . --ext .js,.ts",
    "lint-n-fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write 'packages/*/src/**/*.{js,ts}'",
    "prepare": "echo 'skipping prepare'",
    "typedoc": "typedoc",
    "chat": "node packages/assistant/cli.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "rimraf": "^6.1.0",
    "minimatch": "^10.2.4"
  }
}
